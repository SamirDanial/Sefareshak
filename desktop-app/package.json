{
  "name": "bellami-desktop",
  "version": "1.0.0",
  "description": "Bellami Desktop Application",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:electron && npm run build:react && electron-builder",
    "build:win": "npm run build:electron && npm run build:react && electron-builder --win",
    "build:mac": "npm run build:electron && npm run build:react && electron-builder --mac",
    "build:linux": "npm run build:electron && npm run build:react && electron-builder --linux",
    "build:electron": "node electron/build.mjs",
    "build:react": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:prod": "npm run build:electron && npm run build:react && NODE_ENV=production electron .",
    "lint": "eslint ."
  },
  "keywords": [
    "electron",
    "react",
    "desktop"
  ],
  "author": "Bellami",
  "license": "MIT",
  "dependencies": {
    "@clerk/clerk-react": "^5.53.2",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.6.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.546.0",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.3.3",
    "react-router-dom": "^7.9.4",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/postcss": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "tailwindcss": "^4.1.14",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^8.0.1"
  }
}
