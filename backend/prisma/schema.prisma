model FiscalTransactionCorrection {
  id String @id @default(cuid())

  organizationId     String
  branchId           String
  deviceId           String?
  orderId            String?
  reservationOrderId String?
  refundId           String? @unique

  fiscalTransactionId String
  fiscalTransaction   FiscalTransaction @relation(fields: [fiscalTransactionId], references: [id], onDelete: Cascade)

  type   FiscalCorrectionType
  status FiscalTransactionStatus @default(CREATED)

  amount   Decimal @db.Decimal(10, 2)
  currency String?
  metadata Json?

  clientTransactionId String    @unique
  tssTransactionId    String?
  startedAt           DateTime?
  finishedAt          DateTime?
  signaturePayload    Json?
  errorCode           String?
  errorMessage        String?
  lastAttemptAt       DateTime?
  attemptCount        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
  @@index([orderId])
  @@index([reservationOrderId])
  @@index([deviceId])
  @@index([status])
  @@map("fiscal_transaction_corrections")
}

