  ACTIVE
  PARTIALLY_REDEEMED
  REDEEMED
  EXPIRED
  VOIDED
}

enum VoucherTxType {
  ISSUANCE
  REDEMPTION
  PARTIAL_REDUCTION
  VOID
}

model Voucher {
  id                    String              @id @default(cuid())
  voucherCode           String              @unique
  voucherType           VoucherType
  initialAmount         Decimal             @db.Decimal(10, 2)
  currentAmount         Decimal             @db.Decimal(10, 2)
  vatRate               Decimal?            @db.Decimal(5, 2) // Nullable, populated ONLY for SINGLE_PURPOSE
  status                VoucherStatus       @default(ACTIVE)
  expiresAt             DateTime
  tseIssuanceSignature  String?             @db.Text
  branchId              String?             // Branch where voucher was issued - vouchers can only be redeemed at the same branch
  organizationId        String?             // Organization where voucher was issued
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  transactions          VoucherTransaction[]

  @@map("vouchers")
}

model VoucherTransaction {
  id            String        @id @default(cuid())
  voucherId     String
  txType        VoucherTxType
  amount        Decimal       @db.Decimal(10, 2)
  balanceBefore Decimal       @db.Decimal(10, 2)
  balanceAfter  Decimal       @db.Decimal(10, 2)
  cashierId     String?
  orderId       String?
  createdAt     DateTime      @default(now())

  voucher       Voucher       @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@map("voucher_transactions")
}

model BranchLike {
  id        String   @id @default(cuid())
