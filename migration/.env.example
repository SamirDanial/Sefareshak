# ── Source DB (VPS via SSH) ──────────────────────────────────────────────────
SRC_SSH_HOST=
SRC_SSH_PORT=22
SRC_SSH_USER=
SRC_SSH_KEY_PATH=/path/to/id_rsa        # path to private key file (preferred)
SRC_SSH_PASSWORD=
SRC_SSH_KEY_PASSPHRASE=                  # passphrase to decrypt the private key (leave blank if key has no passphrase)

SRC_DB_HOST=127.0.0.1                   # DB host as seen from INSIDE the VPS (pgAdmin: Connection → Host)
SRC_DB_PORT=5432
SRC_DB_NAME=
SRC_DB_USER=
SRC_DB_PASSWORD=
SRC_DB_CONNECT_TIMEOUT=15               # seconds (pgAdmin: Connection → Connection timeout)
SRC_DB_SSLMODE=prefer                   # pgAdmin: Parameters → sslmode | disable | allow | prefer | require | verify-ca | verify-full
SRC_DB_SSLROOTCERT=                     # pgAdmin: Parameters → sslrootcert | path to CA cert (required for verify-ca / verify-full)
SRC_DB_SSLCERT=                         # pgAdmin: Parameters → sslcert | path to client cert (mutual TLS, usually blank)
SRC_DB_SSLKEY=                          # pgAdmin: Parameters → sslkey | path to client key (mutual TLS, usually blank)
SRC_DB_APPLICATION_NAME=bellami-migration  # pgAdmin: Parameters → application_name (visible in pg_stat_activity)

# ── Destination DB (AWS RDS / Aurora) ────────────────────────────────────────
DST_DB_HOST=mydb.cluster-xxxx.us-east-1.rds.amazonaws.com
DST_DB_PORT=5432
DST_DB_NAME=bellami_dst
DST_DB_USER=postgres
DST_DB_PASSWORD=secret
DST_DB_CONNECT_TIMEOUT=15               # seconds
DST_DB_SSLMODE=prefer                   # prefer | require | verify-ca | verify-full — match your pgAdmin Parameters tab setting
DST_DB_SSLROOTCERT=                     # path to CA cert (for verify-ca / verify-full; AWS provides a bundle)
DST_DB_SSLCERT=                         # path to client cert (mutual TLS, usually blank for RDS)
DST_DB_SSLKEY=                          # path to client key (mutual TLS, usually blank for RDS)
DST_DB_APPLICATION_NAME=bellami-migration

# SSH tunnel for destination — leave ALL blank to connect directly (typical for RDS)
DST_SSH_HOST=
DST_SSH_PORT=22
DST_SSH_USER=
DST_SSH_KEY_PATH=
DST_SSH_KEY_PASSPHRASE=
DST_SSH_PASSWORD=

# ── Image Transfer ────────────────────────────────────────────────────────────
# Absolute path to the uploads root on the SOURCE VPS
SRC_UPLOAD_PATH=/root/Bellami/backend/uploads

# EC2 SSH access (for SFTP file push)
EC2_SSH_HOST=                          # EC2 public IP or domain
EC2_SSH_PORT=22
EC2_SSH_USER=ubuntu                    # default user for Ubuntu AMI; use ec2-user for Amazon Linux
EC2_SSH_KEY_PATH=/Users/samirdanial/.ssh/ec2-key.pem

# Absolute path to the uploads root on the DESTINATION EC2
EC2_UPLOAD_PATH=/root/Bellami/backend/uploads

# Base URL rewrite applied to image columns in the destination DB
SRC_BASE_URL=https://feetages.cloud
DST_BASE_URL=https://nextfoody.com
