// User-Branch assignment (which branches a user can access)
model UserBranch {
  id        String   @id @default(cuid())
  userId    String
  branchId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@map("user_branches")
}

// Role definition with permissions
model Role {
  id             String               @id @default(cuid())
  organizationId String?
  name           String
  description    String?
  permissions    Json // Stores permission object: { "orders": ["view", "create"], "menu": ["view", "update"] }
  isSystem       Boolean              @default(false) // System roles cannot be deleted
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  userRoles      UserRoleAssignment[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

// User-Role assignment (optionally scoped to a branch)
model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  branchId  String? // null = role applies to all assigned branches
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@index([roleId])
  @@index([branchId])
  @@map("user_role_assignments")
}

model Notification {
  id            String           @id @default(cuid())
  orderId       String?
  isSeen        Boolean          @default(false)
  isOrderUpdate Boolean          @default(false)
  seenAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  reservationId String?
  type          NotificationType @default(ORDER)
  order         Order?           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reservation   Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PushSubscription {
  id                   String                     @id @default(cuid())
  userId               String
  endpoint             String                     @unique
  p256dh               String
  auth                 String
  userAgent            String?
  isAppLevelSubscription Boolean                   @default(false) // Track if this is an app-level subscription
  organizationId       String?                    // Organization user primarily interacts with
  branchId             String?                    // Branch user primarily interacts with
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  clicks               PushNotificationClick[]
  deliveries           PushNotificationDelivery[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([branchId])
  @@index([isAppLevelSubscription])
  @@map("push_subscriptions")
}

// Branch click tracking model
model BranchClick {
  id        String   @id @default(cuid())
  branchId  String
  userId    String? // null for unknown/non-logged-in users
  clickTime DateTime @default(now())
  userAgent String? // optional browser/device info
  ipAddress String? // optional IP address for analytics

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([userId])
  @@index([clickTime])
  @@map("branch_clicks")
}

// Branch subscription model - customers can subscribe to branches
model BranchSubscription {
  id        String   @id @default(cuid())
  branchId  String
  userId    String
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
  @@index([userId])
  @@map("branch_subscriptions")
}
// Tablet notification preferences - track which users want tablet notifications
model TabletNotificationPreference {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?  // If set, receive notifications for all branches in org
  branchId       String?  // If set (and orgId null), receive notifications for specific branch
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, branchId])
  @@index([userId])
  @@index([organizationId])
  @@index([branchId])
  @@map("tablet_notification_preferences")
}


model PushNotification {
  id              String                     @id @default(cuid())
  title           String
  message         String
  image           String?
  actionUrl       String?
  actionLabel     String?
  sentBy          String
  totalRecipients Int                        @default(0)
  organizationId  String?                    // Organization that sent the notification
  branchId        String?                    // Specific branch if sent to branch subscribers only
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  clicks          PushNotificationClick[]
  deliveries      PushNotificationDelivery[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([organizationId])
  @@index([branchId])
