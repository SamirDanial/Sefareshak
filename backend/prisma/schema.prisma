  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([subscriptionId])
  @@map("push_notification_deliveries")
}

model PushNotificationClick {
  id             String           @id @default(cuid())
  notificationId String
  subscriptionId String
  clickedAt      DateTime         @default(now())
  notification   PushNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([clickedAt])
  @@map("push_notification_clicks")
}

model HeroSection {
