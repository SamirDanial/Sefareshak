generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String               @id @default(cuid())
  clerkId                     String               @unique
  email                       String?              @unique
  firstName                   String?
  lastName                    String?
  phone                       String?
  description                 String?
  userType                    UserType             @default(USER)
  organizationId              String?
  orgRole                     OrgRole?
  isActive                    Boolean              @default(true)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  hasAcceptedRequiredPolicies Boolean              @default(false)
  orders                      Order[]
  reservations                Reservation[]
  kitchenTickets              KitchenTicket[]
  addresses                   UserAddress[]
  assignedBranches            UserBranch[]
  userRoles                   UserRoleAssignment[]
  branchClicks                BranchClick[]
  branchLikes                 BranchLike[]
  branchSubscriptions         BranchSubscription[]
  tabletNotificationPreferences TabletNotificationPreference[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("users")
}

model Organization {
  id                  String  @id @default(cuid())
  name                String
  slug                String  @unique
  organizationNumber  String  @default("")
  isActive            Boolean @default(true)

  // Organization validation fields
  isValidated         Boolean   @default(false)
  validatedAt         DateTime?
  validatedBy         String? // Super admin who validated
  validationExpiresAt DateTime? // When validation expires
  validationNotes     String? // Notes from super admin
  gracePeriodEndsAt   DateTime? // One week grace period after expiration

  maxActiveBranches     Int?
  freeVersion           Boolean @default(false)
  reservationsAllowed   Boolean @default(true)
  onlinePaymentsAllowed Boolean @default(true)
  cardPaymentsAllowed   Boolean @default(true)
  paypalAllowed         Boolean @default(true)
  vouchersAllowed       Boolean @default(true)

  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  branches           Branch[]
  users              User[]
  validations        OrganizationValidation[]
  validationPayments ValidationPayment[]

  heroSection HeroSection?

  roles Role[]

  settings            Settings?
  reservationSettings ReservationSettings?

  categories          Category[]
  meals               Meal[]
  deals               Deal[]
  addons              AddOn[]
  declarations        Declaration[]
  optionalIngredients OptionalIngredient[]

  posDevices         PosDevice[]
  fiscalTransactions FiscalTransaction[]
  tssOutageLogs      TssOutageLog[]
  pushNotifications  PushNotification[]
  tabletNotificationPreferences TabletNotificationPreference[]
  pushSubscriptions  PushSubscription[]

  @@map("organizations")
}

// Organization validation history model
model OrganizationValidation {
  id                String    @id @default(cuid())
  organizationId    String
  validatedBy       String // Super admin who validated
  validatedAt       DateTime  @default(now())
  expiresAt         DateTime // Flexible date chosen by super admin
  gracePeriodEndsAt DateTime // expiresAt + 7 days
  notes             String? // Validation notes from super admin
  isActive          Boolean   @default(true) // Current active validation
  unvalidatedAt     DateTime? // When validation was temporarily unvalidated
  unvalidatedBy     String? // Super admin who unvalidated

  // Request workflow tracking
  requestedAt  DateTime? // When organization requested validation
  requestedBy  String? // Organization owner who requested
  requestNotes String? // Notes from organization owner

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([validatedBy])
  @@index([expiresAt])
  @@index([gracePeriodEndsAt])
  @@map("organization_validations")
}

// Validation payment tracking model
model ValidationPayment {
  id             String        @id @default(cuid())
  organizationId String
  validationId   String? // Link to specific validation
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?
  transactionId  String? // External transaction ID
  notes          String? // Payment notes

  // Validity period this payment covers
  validFrom  DateTime @default(now())
  validUntil DateTime // Until when this payment makes organization valid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([validationId])
  @@index([paymentStatus])
  @@index([validUntil])
  @@map("validation_payments")
}

model BranchType {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]

  @@map("branch_types")
}

model Category {
  id               String          @id @default(cuid())
  organizationId   String?
  name             String
  description      String?
  taxPercentage    Decimal?        @db.Decimal(5, 2)
  image            String?
  isActive         Boolean         @default(true)
  isFeatured       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  featuredOrder    Int             @default(0)
  listOrder        Int             @default(0)
  excludedBranches String[]        @default([])
  addonCategories  AddonCategory[]
  meals            Meal[]
  deals            Deal[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("categories")
}

model Meal {
  id                      String                   @id @default(cuid())
  organizationId          String?
  sku                     String?
  name                    String
  description             String?
  basePrice               Decimal                  @db.Decimal(10, 2)
  taxPercentage           Decimal?                 @db.Decimal(5, 2)
  image                   String?
  isActive                Boolean                  @default(true)
  isFeatured              Boolean                  @default(false)
  isDrink                 Boolean                  @default(false)
  categoryId              String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  featuredOrder           Int                      @default(0)
  listOrder               Int                      @default(0)
  excludedBranches        String[]                 @default([])
  mealAddOns              MealAddOn[]
  branchPrices            MealBranchPrice[]
  branchAvailabilities    MealBranchAvailability[]
  mealDeclarations        MealDeclaration[]
  mealOptionalIngredients MealOptionalIngredient[]
  mealSizes               MealSize[]
  mealSizeWeights         MealSizeWeight[]
  mealDailyDeliverables   MealDailyDeliverable[]
  category                Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems              OrderItem[]
  reservationOrderItems   ReservationOrderItem[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("meals")
}

model Deal {
  id               String   @id @default(cuid())
  organizationId   String?
  name             String
  description      String?
  sku              String?
  image            String?
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  featuredOrder    Int      @default(0)
  listOrder        Int      @default(0)
  excludedBranches String[] @default([])
  categoryId       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category                Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  components              DealComponent[]
  branchPrices            DealBranchPrice[]
  dealAddOns              DealAddOn[]
  dealDeclarations        DealDeclaration[]
  dealOptionalIngredients DealOptionalIngredient[]
  orderItems              OrderItem[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("deals")
}

model DealComponent {
  id            String   @id @default(cuid())
  dealId        String
  name          String
  price         Decimal  @db.Decimal(10, 2)
  taxPercentage Decimal  @db.Decimal(5, 2)
  quantity      Int      @default(1)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deal         Deal                       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  branchPrices DealComponentBranchPrice[]
  orderItems   OrderItem[]

  @@index([dealId])
  @@map("deal_components")
}

model DealBranchPrice {
  id        String   @id @default(cuid())
  dealId    String
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([dealId, branchId])
  @@index([dealId])
  @@index([branchId])
  @@map("deal_branch_prices")
}

model DealComponentBranchPrice {
  id              String   @id @default(cuid())
  dealComponentId String
  branchId        String
  price           Decimal  @db.Decimal(10, 2)
  taxPercentage   Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dealComponent DealComponent @relation(fields: [dealComponentId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([dealComponentId, branchId])
  @@index([dealComponentId])
  @@index([branchId])
  @@map("deal_component_branch_prices")
}

model DealAddOn {
  id      String @id @default(cuid())
  dealId  String
  addOnId String

  deal  Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  addOn AddOn @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@unique([dealId, addOnId])
  @@map("deal_addons")
}

model DealDeclaration {
  id            String @id @default(cuid())
  dealId        String
  declarationId String

  deal        Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  declaration Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@unique([dealId, declarationId])
  @@map("deal_declarations")
}

model DealOptionalIngredient {
  id                   String @id @default(cuid())
  dealId               String
  optionalIngredientId String

  deal               Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  optionalIngredient OptionalIngredient @relation(fields: [optionalIngredientId], references: [id], onDelete: Cascade)

  @@unique([dealId, optionalIngredientId])
  @@map("deal_optional_ingredients")
}

model MealSize {
  id              String           @id @default(cuid())
  name            String
  price           Decimal          @db.Decimal(10, 2)
  taxPercentage   Decimal?         @db.Decimal(5, 2)
  mealId          String
  sizeType        SizeType         @default(M)
  meal            Meal             @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealSizeWeights MealSizeWeight[]

  @@unique([mealId, name])
  @@map("meal_sizes")
}

model MealBranchPrice {
  id            String   @id @default(cuid())
  mealId        String
  branchId      String
  basePrice     Decimal  @db.Decimal(10, 2)
  taxPercentage Decimal? @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  meal          Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([mealId, branchId])
  @@index([mealId])
  @@index([branchId])
  @@map("meal_branch_prices")
}

model MealBranchAvailability {
  id                 String   @id @default(cuid())
  mealId             String
  branchId           String
  isAvailableAllWeek Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  meal    Meal                           @relation(fields: [mealId], references: [id], onDelete: Cascade)
  branch  Branch                         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  windows MealBranchAvailabilityWindow[]

  @@unique([mealId, branchId])
  @@index([mealId])
  @@index([branchId])
  @@map("meal_branch_availabilities")
}

model MealBranchAvailabilityWindow {
  id             String   @id @default(cuid())
  availabilityId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  availability MealBranchAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("meal_branch_availability_windows")
}

// Weight per meal size per branch (used for deliverable quantity calculations)
model MealSizeWeight {
  id         String   @id @default(cuid())
  mealId     String
  mealSizeId String
  branchId   String
  weight     Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meal     Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealSize MealSize @relation(fields: [mealSizeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([mealId, mealSizeId, branchId])
  @@index([mealId, branchId])
  @@index([branchId])
  @@map("meal_size_weights")
}

// Daily deliverable weight limit per meal per branch (applies every day)
model MealDailyDeliverable {
  id                     String   @id @default(cuid())
  mealId                 String
  branchId               String
  dailyDeliverableWeight Decimal  @db.Decimal(10, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([mealId, branchId])
  @@index([mealId, branchId])
  @@map("meal_daily_deliverables")
}

model AddonBranchPrice {
  id            String   @id @default(cuid())
  addonId       String
  branchId      String
  basePrice     Decimal  @db.Decimal(10, 2)
  taxPercentage Decimal? @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  addon         AddOn    @relation(fields: [addonId], references: [id], onDelete: Cascade)
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([addonId, branchId])
  @@index([addonId])
  @@index([branchId])
  @@map("addon_branch_prices")
}

model AddOn {
  id                         String                      @id @default(cuid())
  organizationId             String?
  name                       String
  description                String?
  sku                        String?                     // Article number for DSFinV-K export
  price                      Decimal?                    @db.Decimal(10, 2)
  taxPercentage              Decimal?                    @db.Decimal(5, 2)
  image                      String?
  type                       AddOnType                   @default(BOOLEAN)
  isActive                   Boolean                     @default(true)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  excludedBranches           String[]                    @default([])
  addonBranchPrices          AddonBranchPrice[]
  addonCategories            AddonCategory[]
  addonSizes                 AddonSize[]
  mealAddOns                 MealAddOn[]
  dealAddOns                 DealAddOn[]
  orderItemAddOns            OrderItemAddOn[]
  reservationOrderItemAddOns ReservationOrderItemAddOn[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("addons")
}

model AddonSize {
  id            String   @id @default(cuid())
  addonId       String
  sizeType      SizeType
  price         Decimal  @db.Decimal(10, 2)
  taxPercentage Decimal? @db.Decimal(5, 2)
  addon         AddOn    @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([addonId, sizeType])
  @@map("addon_sizes")
}

model MealAddOn {
  id      String @id @default(cuid())
  mealId  String
  addOnId String
  addOn   AddOn  @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  meal    Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([mealId, addOnId])
  @@map("meal_addons")
}

model AddonCategory {
  id         String   @id @default(cuid())
  addonId    String
  categoryId String
  addon      AddOn    @relation(fields: [addonId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([addonId, categoryId])
  @@map("addon_categories")
}

model Declaration {
  id               String            @id @default(cuid())
  organizationId   String?
  name             String
  type             String?
  description      String?
  icon             String?
  shownInFilter    Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  excludedBranches String[]          @default([])
  mealDeclarations MealDeclaration[]
  dealDeclarations DealDeclaration[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("declarations")
}

model MealDeclaration {
  id            String      @id @default(cuid())
  mealId        String
  declarationId String
  declaration   Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  meal          Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([mealId, declarationId])
  @@map("meal_declarations")
}

model OptionalIngredient {
  id                                      String                                   @id @default(cuid())
  organizationId                          String?
  name                                    String
  description                             String?
  createdAt                               DateTime                                 @default(now())
  updatedAt                               DateTime                                 @updatedAt
  mealOptionalIngredients                 MealOptionalIngredient[]
  dealOptionalIngredients                 DealOptionalIngredient[]
  orderItemOptionalIngredients            OrderItemOptionalIngredient[]
  reservationOrderItemOptionalIngredients ReservationOrderItemOptionalIngredient[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("optional_ingredients")
}

model MealOptionalIngredient {
  id                   String             @id @default(cuid())
  mealId               String
  optionalIngredientId String
  meal                 Meal               @relation(fields: [mealId], references: [id], onDelete: Cascade)
  optionalIngredient   OptionalIngredient @relation(fields: [optionalIngredientId], references: [id], onDelete: Cascade)

  @@unique([mealId, optionalIngredientId])
  @@map("meal_optional_ingredients")
}

model Order {
  id                           String        @id @default(cuid())
  orderNumber                  String        @unique
  userId                       String?
  status                       OrderStatus   @default(PENDING)
  billSnapshot                 Json?         // Immutable bill snapshot created at order creation
  orderType                    OrderType     @default(DELIVERY)
  taxInclusive                 Boolean       @default(false)
  isMerged                     Boolean       @default(false)
  isPosOrder                   Boolean       @default(false)
  mergedAt                     DateTime?
  confirmedAt                  DateTime?
  preparationTime              Int?
  totalAmount                  Decimal       @db.Decimal(10, 2)
  currency                     String        @default("usd")
  deliveryFee                  Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount                    Decimal       @default(0) @db.Decimal(10, 2)
  itemTaxAmount                Decimal       @default(0) @db.Decimal(10, 2)
  addonTaxAmount               Decimal       @default(0) @db.Decimal(10, 2)
  deliveryTaxAmount            Decimal       @default(0) @db.Decimal(10, 2)
  businessDaySessionId         String?
  paymentMethod                PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus                PaymentStatus @default(PENDING)
  paymentIntentId              String?       @unique
  paymentId                    String?       @unique
  payment                      Payment?      @relation("PaymentOrderLink")
  deliveryAddress              String?
  deliveryStreetAddress        String?
  deliveryHouseNumber          String?
  deliveryPostalCode           String?
  deliveryBuilding             String?
  deliveryFloor                String?
  deliveryApartment            String?
  deliveryPhone                String?
  deliveryNotes                String?
  pickupPhone                  String?
  pickupNotes                  String?
  guestName                    String?
  guestEmail                   String?
  guestPhone                   String?
  deliveryDistanceKm           Decimal?      @db.Decimal(10, 4)
  takeawayServiceFee           Decimal?      @db.Decimal(10, 2)
  takeawayServiceTaxPercentage Decimal       @default(0) @db.Decimal(5, 2)
  takeawayServiceTaxAmount     Decimal       @default(0) @db.Decimal(10, 2)
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  branchId                     String?
  deliveryExtraDetails         String?

  // Cancel + New Order modification linkage
  replacesOrderId   String? @unique
  replacesOrder     Order?  @relation("OrderReplacement", fields: [replacesOrderId], references: [id])
  replacementOrders Order[] @relation("OrderReplacement")

  // History timeline (similar to ReservationOrder.history)
  history Json?

  // Cancellation reason (when order is cancelled)
  cancellationReason String?

  // Discount fields (POS order-level discount, applied pre-tax)
  discountType   String? // "FIXED" | "PERCENTAGE" | null
  discountValue  Decimal? @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)

  // Voucher payment fields
  voucherPaymentAmount Decimal @default(0) @db.Decimal(10, 2)
  voucherCodes        String[] @default([])
  voucherRemainingBalances Json? // Store { [code: string]: remainingBalance } snapshot at transaction time

  // Scheduled/Future Order fields
  scheduledDate      DateTime? // The date/time the order is scheduled for (null = ASAP/today)
  isScheduledOrder   Boolean             @default(false)
  // Fiscal posting timestamp (Germany-style EOD): set when the transaction is finalized
  postedAt           DateTime?
  notifications      Notification[]
  orderItems         OrderItem[]
  branch             Branch?             @relation(fields: [branchId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  refunds            Refund[]
  businessDaySession BusinessDaySession? @relation(fields: [businessDaySessionId], references: [id])
  adjustments        OrderAdjustment[]

  fiscalTransaction FiscalTransaction? @relation("FiscalTransactionOrder")
  fiscalSigningQueue FiscalSigningQueue?

  @@index([paymentId])
  @@index([scheduledDate])
  @@index([isScheduledOrder])
  @@index([businessDaySessionId])
  @@index([postedAt])
  @@map("orders")
}

model BusinessDaySession {
  id             String            @id @default(cuid())
  branchId       String
  sequenceNumber Int
  status         BusinessDayStatus @default(OPEN)
  startedAt      DateTime          @default(now())
  endedAt        DateTime?
  closedByUserId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  branch              Branch                        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders              Order[]
  reservationOrders   ReservationOrder[]
  report              BusinessDayReport?
  dsfinvkSubmission   BusinessDayDsfinvkSubmission?
  appliedAdjustments  OrderAdjustment[]             @relation("AppliedBusinessDayAdjustments")
  originalAdjustments OrderAdjustment[]             @relation("OriginalBusinessDayAdjustments")

  @@unique([branchId, sequenceNumber])
  @@index([branchId, status])
  @@map("business_day_sessions")
}

model BusinessDayReport {
  id        String   @id @default(cuid())
  sessionId String   @unique
  data      Json
  createdAt DateTime @default(now())

  session BusinessDaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("business_day_reports")
}

model BusinessDayDsfinvkSubmission {
  id        String  @id @default(cuid())
  sessionId String  @unique
  ok        Boolean
  error     String?

  fiskalyOrganizationId    String?
  cashRegisterId           String?
  cashRegisterExportId     String?
  cashPointClosingExportId String?
  exportId                 String?

  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session BusinessDaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([cashRegisterId])
  @@index([cashPointClosingExportId])
  @@index([exportId])
  @@map("business_day_dsfinvk_submissions")
}

model OrderAdjustment {
  id                String              @id @default(cuid())
  branchId          String
  type              OrderAdjustmentType
  status            RefundStatus        @default(PENDING)
  amount            Decimal             @db.Decimal(10, 2)
  currency          String
  originalOrderId   String?
  originalSessionId String?
  appliedSessionId  String?
  refundId          String?
  createdByUserId   String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  originalOrder   Order?              @relation(fields: [originalOrderId], references: [id], onDelete: SetNull)
  refund          Refund?             @relation(fields: [refundId], references: [id], onDelete: SetNull)
  originalSession BusinessDaySession? @relation("OriginalBusinessDayAdjustments", fields: [originalSessionId], references: [id], onDelete: SetNull)
  appliedSession  BusinessDaySession? @relation("AppliedBusinessDayAdjustments", fields: [appliedSessionId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([appliedSessionId])
  @@index([originalSessionId])
  @@map("order_adjustments")
}

model OrderItem {
  id                           String                        @id @default(cuid())
  orderId                      String
  itemType                     OrderItemType                 @default(MEAL)
  mealId                       String?
  dealId                       String?
  dealComponentId              String?
  parentDealItemId             String?
  quantity                     Int
  unitPrice                    Decimal                       @db.Decimal(10, 2)
  totalPrice                   Decimal                       @db.Decimal(10, 2)
