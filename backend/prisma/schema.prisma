model Reservation {
  id                          String             @id @default(cuid())
  reservationNumber           String             @unique
  userId                      String?
  tableId                     String?
  status                      ReservationStatus  @default(PENDING)
  type                        ReservationType    @default(SIMPLE)
  reservationDate             DateTime
  numberOfGuests              Int
  customerName                String
  customerEmail               String
  customerPhone               String
  specialRequests             String?
  preferredZone               String?
  paymentStatus               PaymentStatus?
  paymentIntentId             String?            @unique
  paymentId                   String?
  confirmedAt                 DateTime?
  seatedAt                    DateTime?
  completedAt                 DateTime?
  cancelledAt                 DateTime?
  cancelledBy                 String?
  cancellationReason          String?
  internalNotes               String?
  noShow                      Boolean            @default(false)
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  reservationOrderId          String?            @unique
  incrementalPaymentIntentIds String?
  branchId                    String?
  zoneId                      String?
  tableIds                    String[]           @default([])
  notifications               Notification[]
  tables                      ReservationTable[]
  kitchenTickets              KitchenTicket[]
  branch                      Branch?            @relation(fields: [branchId], references: [id])
  reservationOrder            ReservationOrder?  @relation("ReservationOrder", fields: [reservationOrderId], references: [id])
  table                       Table?             @relation(fields: [tableId], references: [id])
  user                        User?              @relation(fields: [userId], references: [id])
  zone                        Zone?              @relation(fields: [zoneId], references: [id])

  @@index([reservationDate])
  @@index([status])
  @@index([type])
  @@index([userId])
  @@index([tableId])
  @@index([reservationOrderId])
  @@index([paymentId])
  @@map("reservations")
}

model Zone {
  id              String         @id @default(cuid())
  branchId        String
  name            String
  description     String?
  isActive        Boolean        @default(true)
  capacity        Int?
  canvasWidth     Int?           @default(800)
  canvasHeight    Int?           @default(600)
  backgroundImage String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  reservations    Reservation[]
  tables          Table[]        @relation("ZoneTables")
  floorElements   FloorElement[]
  branch          Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, name])
  @@index([branchId])
  @@map("zones")
}

model Table {
  id                String             @id @default(cuid())
  tableNumber       String
  capacity          Int
  zone              String?
  status            TableStatus        @default(AVAILABLE)
  isActive          Boolean            @default(true)
  notes             String?
  positionX         Float?             @default(0)
  positionY         Float?             @default(0)
  width             Float?             @default(60)
  height            Float?             @default(60)
  rotation          Float?             @default(0)
  shape             String?            @default("SQUARE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  branchId          String?
  zoneId            String?
  reservationTables ReservationTable[]
  reservations      Reservation[]
  branch            Branch?            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  zoneRelation      Zone?              @relation("ZoneTables", fields: [zoneId], references: [id])

  @@index([branchId])
  @@index([zoneId])
  @@map("tables")
}

model ReservationTable {
  id            String      @id @default(cuid())
  reservationId String
  tableId       String
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table         Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([reservationId, tableId])
  @@index([reservationId])
  @@index([tableId])
  @@map("reservation_tables")
}

model FloorElement {
  id        String   @id @default(cuid())
  zoneId    String
  type      String // WINDOW, DOOR, STAIRS, GARDEN, WALL, BAR, KITCHEN, RESTROOM, PLANT, PILLAR, LABEL
  label     String?
  positionX Float    @default(0)
  positionY Float    @default(0)
  width     Float    @default(50)
  height    Float    @default(50)
  rotation  Float    @default(0)
  color     String?
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@map("floor_elements")
}

model ReservationOrder {
  id                   String                 @id @default(cuid())
  orderNumber          String                 @unique
  reservationId        String?                @unique
  branchId             String?
  businessDaySessionId String?
  totalAmount          Decimal                @db.Decimal(10, 2)
  currency             String                 @default("usd")
  taxAmount            Decimal                @default(0) @db.Decimal(10, 2)
  itemTaxAmount        Decimal                @default(0) @db.Decimal(10, 2)
  addonTaxAmount       Decimal                @default(0) @db.Decimal(10, 2)
  paymentMethod        PaymentMethod          @default(ONLINE_PAYMENT)
  paymentStatus        PaymentStatus          @default(PAID)
  paymentIntentId      String?                @unique
  paymentId            String?                @unique
  paidAmount           Decimal                @default(0) @db.Decimal(10, 2)
  depositPercentage    Decimal?               @db.Decimal(5, 2)
  customerName         String
  customerEmail        String
  customerPhone        String
  status               OrderStatus            @default(PENDING)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  // Fiscal posting timestamp (Germany-style EOD): set when the reservation transaction is finalized
  postedAt             DateTime?
  history              Json?
  items                ReservationOrderItem[]
  reservation          Reservation?           @relation("ReservationOrder")
  payment              Payment?               @relation("PaymentReservationOrderLink")
  refunds              Refund[]
  branch               Branch?                @relation(fields: [branchId], references: [id])
  businessDaySession   BusinessDaySession?    @relation(fields: [businessDaySessionId], references: [id])

  fiscalTransaction FiscalTransaction? @relation("FiscalTransactionReservationOrder")

  @@index([reservationId])
  @@index([paymentIntentId])
  @@index([paymentId])
  @@index([status])
  @@index([postedAt])
  @@index([branchId])
  @@index([businessDaySessionId])
  @@map("reservation_orders")
}

model Payment {
  id                 String            @id @default(cuid())
  orderId            String?           @unique
  reservationOrderId String?           @unique
  paymentMethod      PaymentMethod
  paymentProvider    PaymentProvider
  providerPaymentId  String?           @unique
  providerChargeId   String?           @unique
  amount             Decimal           @db.Decimal(10, 2)
  currency           String            @default("usd")
  fees               Decimal?          @db.Decimal(10, 2)
  netAmount          Decimal?          @db.Decimal(10, 2)
  status             PaymentState      @default(PENDING)
  metadata           Json?
  webhookData        Json?
  createdAt          DateTime          @default(now())
  completedAt        DateTime?
  failedAt           DateTime?
  refundedAt         DateTime?
  order              Order?            @relation("PaymentOrderLink", fields: [orderId], references: [id])
  reservationOrder   ReservationOrder? @relation("PaymentReservationOrderLink", fields: [reservationOrderId], references: [id])
  refunds            Refund[]

  @@index([orderId])
  @@index([reservationOrderId])
  @@index([providerPaymentId])
  @@index([providerChargeId])
  @@map("payments")
}

model ReservationOrderItem {
  id                  String                                   @id @default(cuid())
  reservationOrderId  String
  mealId              String
  quantity            Int
  unitPrice           Decimal                                  @db.Decimal(10, 2)
  totalPrice          Decimal                                  @db.Decimal(10, 2)
  taxAmount           Decimal                                  @default(0) @db.Decimal(10, 2)
  taxPercentage       Decimal                                  @default(0) @db.Decimal(5, 2)
  selectedSize        String?
  mealSizeType        SizeType?
