model ReservationOrderItemAddOn {
  id                     String               @id @default(cuid())
  reservationOrderItemId String
  addon_id               String?
  addOnName              String
  addOnPrice             Decimal              @db.Decimal(10, 2)
  taxAmount              Decimal              @default(0) @db.Decimal(10, 2)
  taxPercentage          Decimal              @default(0) @db.Decimal(5, 2)
  addon_type             AddOnType            @default(BOOLEAN)
  addonSizeType          SizeType?
  quantity               Int                  @default(1)
  addon_description      String?
  addon                  AddOn?               @relation(fields: [addon_id], references: [id])
